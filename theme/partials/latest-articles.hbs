{{! Composant réutilisable : Liste des dernières actualités}}
{{! Paramètres :
- limit : nombre d'articles à afficher (défaut: 3)
- excludeId : ID de l'article à exclure (optionnel)
}}

<div class="mx-auto max-w-4xl p-6">
  <h2 class="text-2xl font-bold">Dernières actualités</h2>
  <hr class="border-primary mb-8 border-t-2 w-44 -ml-6">

  <div class="space-y-4">
    {{#get "posts" limit="3" filter="id:-{{excludeId}}"}}
    {{#foreach posts}}
    <article class="">
      <a href="{{url}}" class="flex items-center gap-4">
        {{! Image miniature}}
        {{#if feature_image}}
          <img src="{{feature_image}}" alt="{{title}}" class="w-30 h-full object-cover" />
        {{else}}
          <div class="w-30 h-full bg-gray-200"></div>
        {{/if}}

        {{! Contenu de la carte}}
        <div class="flex-1">
          <h3 class="mb-2 font-semibold">
            {{title}}
          </h3>

          <div class="flex gap-2 flex-wrap justify-between">
            <span class="text-gray-500">
              {{date format="DD/MM/YY"}}
            </span>
            <span class="bg-primary inline-flex items-center rounded-full px-4 py-1 text-xs font-semibold text-white">
              En savoir plus
            </span>
          </div>
        </div>
      </a>
    </article>
    {{/foreach}}
    {{/get}}
  </div>
</div>