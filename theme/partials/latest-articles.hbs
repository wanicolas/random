{{! Composant réutilisable : Liste des dernières actualités}}
{{! Paramètres :
- limit : nombre d'articles à afficher (défaut: 3)
- excludeId : ID de l'article à exclure (optionnel)
}}

<div class="mx-auto max-w-4xl p-4 md:px-6">
  <h2 class="text-2xl font-bold">Dernières actualités</h2>
  <div class="bg-primary mb-8 h-0.75 w-44 -ml-4 md:-ml-6"></div>

  <div class="space-y-4">
    {{#get "posts" limit="3"}}
    {{#foreach posts}}
    <article class="overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition hover:shadow-md">
      <a href="{{url}}" class="flex items-center gap-4 p-4">
        {{! Image miniature}}
        {{#if feature_image}}
        <div class="size-24 flex-shrink-0 overflow-hidden rounded-lg bg-gray-100">
          <img src="{{feature_image}}" alt="{{title}}" class="h-full w-full object-cover" />
        </div>
        {{else}}
        <div class="h-24 w-24 flex-shrink-0 rounded-lg bg-gradient-to-br from-gray-200 to-gray-300"></div>
        {{/if}}

        {{! Contenu de la carte}}
        <div class="min-w-0 flex-1">
          <h3 class="mb-2 line-clamp-2 text-base font-semibold text-gray-900">
            {{title}}
          </h3>
          <span class="bg-primary inline-flex items-center rounded-full px-4 py-1 text-xs font-semibold text-white">
            En savoir plus
          </span>
        </div>

        {{!Date}}
        <div class="flex-shrink-0 text-sm text-gray-500">
          {{date format="DD/MM/YY"}}
        </div>
      </a>
    </article>
    {{/foreach}}
    {{/get}}
  </div>
</div>