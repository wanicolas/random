{{!< default}} {{#post}} <style>
    body,
    .site-main,
    .site-main .container {
    background-color: #ffffff !important;
    max-width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    }
    </style>

    <article class="min-h-screen bg-white text-black font-sans pb-32">
        <div class="max-w-xl mx-auto px-6 py-8">

            {{! ---- TITRE ---- }}
            <header class="text-center mb-6">
                <h1 class="text-[32px] font-extrabold text-primary mb-3">
                    {{title}}
                </h1>
                <div class="h-[2px] w-56 bg-primary mx-auto"></div>
            </header>

            {{! ---- IMAGE DE L'EQUIPE AVEC DECOUPE L'EKIP ---- }}
            <div class="relative mb-6 mt-6">
                <div class="rounded-[1.5rem] overflow-hidden shadow-lg relative">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}" class="w-full h-56 object-cover" />
                    {{else}}
                    <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=1000&auto=format&fit=crop"
                        alt="L'EKIP" class="w-full h-56 object-cover" />
                    {{/if}}
                    <div class="absolute bottom-3 right-4 text-white text-[9px] font-medium drop-shadow-md">
                        *les 2 autres en visios
                    </div>
                </div>

                {{! Faux 'cutout' blanc pour le badge L'EKIP en haut à droite }}
                <div class="absolute -top-3 -right-2 bg-white rounded-bl-[1.5rem] pl-4 pb-4">
                    <div class="flex items-center gap-1.5 px-2">
                        <i data-lucide="users" class="size-4 text-secondary"></i>
                        <span class="text-secondary text-[12px] font-bold uppercase tracking-wider">L'EKIP</span>
                    </div>
                </div>
            </div>

            {{! ---- SEPARATEUR 2 ---- }}
            <div class="flex justify-center mb-10">
                <div class="h-[2px] w-[50%] bg-primary"></div>
            </div>

            {{! ---- FORMULAIRE DE CONTACT ---- }}
            <form class="space-y-4 max-w-sm mx-auto" onsubmit="return false;">

                {{! Prénom + Nom }}
                <div class="flex gap-4">
                    <div class="flex-1">
                        <label class="block text-[10px] font-medium text-primary mb-1 pl-1" for="prenom">Prénom</label>
                        <input id="prenom" type="text" placeholder="Prénom"
                            class="w-full bg-[#f4f4f4] rounded-full px-4 py-2.5 text-xs text-gray-800 placeholder:text-gray-300 outline-none focus:ring-2 focus:ring-primary/30 transition-all border-none" />
                    </div>
                    <div class="flex-1">
                        <label class="block text-[10px] font-medium text-primary mb-1 pl-1" for="nom">Nom</label>
                        <input id="nom" type="text" placeholder="Nom"
                            class="w-full bg-[#f4f4f4] rounded-full px-4 py-2.5 text-xs text-gray-800 placeholder:text-gray-300 outline-none focus:ring-2 focus:ring-primary/30 transition-all border-none" />
                    </div>
                </div>

                {{! Email }}
                <div>
                    <label class="block text-[10px] font-medium text-primary mb-1 pl-1" for="email">Email</label>
                    <div class="relative">
                        <input id="email" type="email"
                            class="w-full bg-[#f4f4f4] rounded-full pl-10 pr-4 py-2.5 text-xs text-gray-800 outline-none focus:ring-2 focus:ring-primary/30 transition-all border-none" />
                        <i data-lucide="mail"
                            class="absolute left-3.5 top-1/2 -translate-y-1/2 size-3.5 text-primary pointer-events-none"></i>
                    </div>
                </div>

                {{! Message }}
                <div>
                    <label class="block text-[10px] font-medium text-primary mb-1 pl-1" for="message">Message</label>
                    <textarea id="message" rows="5" placeholder="Écrivez votre message..."
                        class="w-full bg-[#f4f4f4] rounded-[1.25rem] px-4 py-3 text-xs text-gray-800 placeholder:text-gray-300 outline-none focus:ring-2 focus:ring-primary/30 transition-all resize-none border-none"></textarea>
                </div>

                {{! Bouton Envoyer }}
                <div class="flex justify-center pt-2">
                    <button type="submit"
                        class="bg-primary text-white font-bold text-[13px] px-6 py-2 rounded-full flex items-center gap-1.5 hover:opacity-90 transition-opacity">
                        Envoyer
                        <i data-lucide="send" class="size-3.5 fill-none"></i>
                    </button>
                </div>

            </form>

        </div>
    </article>
    {{/post}}