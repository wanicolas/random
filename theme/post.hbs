{{!< default}}

{{#post}}
<article class="min-h-screen bg-gradient-to-b from-gray-50 to-white">
    {{! Container principal }}
    <div class="max-w-4xl mx-auto">
        
        {{! Bouton retour }}
        <div class="px-4 sm:px-6 lg:px-8 pt-6">
            <a href="{{@site.url}}" 
               class="inline-flex items-center gap-2 bg-[var(--color-primary)] text-white text-xs sm:text-sm font-bold px-5 py-2.5 rounded-full hover:scale-105 hover:shadow-lg transition-all duration-200 shadow-md">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Retour
            </a>
        </div>

        {{! Image featured avec overlay et tags }}
        {{#if feature_image}}
        <div class="px-4 sm:px-6 lg:px-8 pt-6">
            <div class="relative rounded-3xl overflow-hidden shadow-2xl group">
                <img src="{{feature_image}}" 
                     alt="{{title}}" 
                     class="w-full h-64 sm:h-80 md:h-96 object-cover transition-transform duration-500 group-hover:scale-105">
                
                {{! Overlay gradient }}
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
                
                {{! Tags sur l'image }}
                {{#if tags}}
                <div class="absolute top-4 right-4 flex flex-wrap gap-2">
                    {{#foreach tags}}
                    <span class="bg-[var(--color-primary)] text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg backdrop-blur-sm">
                        {{name}}
                    </span>
                    {{/foreach}}
                </div>
                {{/if}}
            </div>
            
            {{! Ligne décorative rose }}
            <div class="w-48 h-1 bg-[var(--color-primary)] mt-6 rounded-full"></div>
        </div>
        {{/if}}
        
        {{! Header avec titre et méta }}
        <header class="px-4 sm:px-6 lg:px-8 pt-8 pb-4">
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6 tracking-tight">
                {{title}}
            </h1>
            
            {{! Meta informations }}
            <div class="flex flex-wrap items-center gap-4 text-sm">
                {{#if primary_author}}
                <div class="flex items-center gap-2">
                    {{#if primary_author.profile_image}}
                    <img src="{{primary_author.profile_image}}" 
                         alt="{{primary_author.name}}" 
                         class="w-10 h-10 rounded-full object-cover border-2 border-[var(--color-primary)]">
                    {{else}}
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-secondary)] flex items-center justify-center text-white font-bold text-lg">
                        A
                    </div>
                    {{/if}}
                    <div class="flex flex-col">
                        <span class="text-xs text-gray-500 uppercase tracking-wide">Auteur</span>
                        <span class="font-semibold text-gray-900">{{primary_author.name}}</span>
                    </div>
                </div>
                {{/if}}
                
                <div class="flex items-center gap-2 text-[var(--color-secondary)]">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <time datetime="{{date format="YYYY-MM-DD"}}" class="font-semibold">
                        {{date format="DD.MM.YYYY"}}
                    </time>
                </div>
                
                {{#if reading_time}}
                <div class="flex items-center gap-2 text-gray-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span>{{reading_time}}</span>
                </div>
                {{/if}}
            </div>
        </header>

        {{! Contenu de l'article avec typographie améliorée }}
        <div class="px-4 sm:px-6 lg:px-8 pb-12">
            <div class="prose prose-lg max-w-none
                        prose-headings:font-bold prose-headings:text-gray-900 prose-headings:tracking-tight
                        prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6
                        prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4
                        prose-p:text-gray-700 prose-p:leading-relaxed prose-p:text-base prose-p:mb-6
                        prose-a:text-[var(--color-primary)] prose-a:font-semibold prose-a:no-underline hover:prose-a:underline
                        prose-strong:text-[var(--color-primary)] prose-strong:font-bold
                        prose-ul:my-6 prose-ul:space-y-2
                        prose-li:text-gray-700
                        prose-img:rounded-2xl prose-img:shadow-lg prose-img:my-8
                        prose-blockquote:border-l-4 prose-blockquote:border-[var(--color-primary)] prose-blockquote:pl-6 prose-blockquote:italic prose-blockquote:text-gray-600
                        prose-code:text-[var(--color-secondary)] prose-code:bg-gray-100 prose-code:px-2 prose-code:py-1 prose-code:rounded">
                {{content}}
            </div>
        </div>
    </div>

    {{! Section Dernières actualités avec fond }}
    <div class="bg-gray-50 mt-12 pt-8">
        <div class="max-w-4xl mx-auto">
            {{> "latest-articles" excludeId=id}}
        </div>
    </div>
</article>
{{/post}}
