{{!< default}}

{{#post}}
<article class="min-h-screen bg-white">
    {{! Bouton retour }}
    <div class="px-6 pt-6">
        <a href="{{@site.url}}" class="inline-flex items-center gap-2 bg-primary text-white text-sm font-semibold px-6 py-2 rounded-full hover:opacity-90 transition">
            ← Retour
        </a>
    </div>

    {{! Image featured }}
    {{#if feature_image}}
    <div class="px-6 pt-6">
        <div class="rounded-2xl overflow-hidden shadow-lg">
            <img src="{{feature_image}}" alt="{{title}}" class="w-full h-300 object-cover">
        </div>
    </div>
    {{/if}}
    
    {{! Titre de l'article }}
    <header class="px-6 pt-8 pb-6">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight">{{title}}</h1>
    </header>

    {{! Contenu de l'article }}
    <div class="px-6 pb-8">
        <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
            {{content}}
        </div>
    </div>

    {{! Section Dernières actualités }}
    {{> "latest-articles" excludeId=id}}
</article>
{{/post}}
