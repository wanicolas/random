{{!< default}}

<section class="relative min-h-screen overflow-hidden px-4 pb-24 pt-8 sm:px-6 lg:px-8 lg:pt-14">
    <div class="relative mx-auto w-full max-w-6xl">
        <header class="mb-8 lg:mb-10">
            <div class="mb-7 flex flex-col items-center gap-3">
                <h1 class="text-5xl font-bold text-primary sm:text-6xl">Articles</h1>
                <div class="h-1 w-52 rounded-full bg-primary"></div>
            </div>

            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:gap-8">
                <label class="relative col-span-1" aria-label="Recherche d'articles">
                    <input
                        id="searchInput"
                        type="search"
                        placeholder="Rechercher..."
                        class="w-full rounded-full border-2 border-primary bg-transparent py-2 pl-11 pr-4 text-sm font-semibold text-fake-black placeholder:font-semibold placeholder:text-[#d0cfd2] focus:outline-none"
                    />
                    <i data-lucide="search" class="absolute left-3 top-1/2 size-5 -translate-y-1/2 text-primary"></i>
                </label>

                <div class="hidden lg:flex lg:flex-1"></div>

                <label class="relative inline-flex items-center lg:ml-auto" aria-label="Filtre par thème">
                    <i data-lucide="filter" class="pointer-events-none absolute left-3 top-1/2 size-4 -translate-y-1/2 text-white"></i>
                    <select
                        id="themeFilter"
                        class="min-w-[7.5rem] appearance-none rounded-full bg-primary py-2 pl-9 pr-8 text-sm font-bold text-white outline-none"
                    >
                        <option value="">Filtres</option>
                    </select>
                    <i data-lucide="chevron-down" class="pointer-events-none absolute right-3 top-1/2 size-4 -translate-y-1/2 text-white"></i>
                </label>
            </div>
        </header>

        <div id="articlesGrid" class="grid grid-cols-1 gap-0 lg:grid-cols-3 lg:gap-x-9 lg:gap-y-12">
            {{#foreach posts}}
            <article class="group border-b-2 border-neutral-300 py-6 first:pt-0 last:border-b-0 lg:border-b-0 lg:py-0" data-theme="{{#if primary_tag}}{{primary_tag.name}}{{/if}}">
                <a href="{{url}}" class="block">
                    <div class="flex items-start gap-4 lg:block lg:space-y-3">
                        <div class="h-24 w-[8.5rem] shrink-0 overflow-hidden rounded-2xl bg-neutral-300 sm:h-28 sm:w-[9.5rem] lg:h-[11.75rem] lg:w-full lg:rounded-xl">
                            {{#if feature_image}}
                            <img src="{{feature_image}}" alt="{{title}}" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
                            {{else}}
                            <div class="h-full w-full bg-gradient-to-br from-primary to-secondary"></div>
                            {{/if}}
                        </div>

                        <div class="min-w-0 flex-1 lg:space-y-2">
                            <h2 class="!font-sans text-[2.25rem] leading-[0.95] font-bold text-fake-black line-clamp-2 lg:text-4xl lg:leading-[1.04]">
                                {{title}}
                            </h2>
                            <div class="mt-3 flex items-center justify-between gap-4 lg:mt-2">
                                <time datetime="{{date format='YYYY-MM-DD'}}" class="text-xs font-light text-black/55 sm:text-sm">
                                    {{date format="DD.MM.YYYY"}}
                                </time>
                            <span class="inline-flex shrink-0 items-center rounded-full bg-primary px-2 py-1 text-sm font-bold leading-none text-white sm:px-3 whitespace-nowrap">En savoir plus</span>
                            </div>
                        </div>
                    </div>
                </a>
            </article>
            {{/foreach}}
        </div>

        <div
            id="articlesPagination"
            class="mt-8 flex justify-center pb-4 lg:mt-10"
            data-current-page="{{pagination.page}}"
            data-total-pages="{{pagination.pages}}"
        >
            <div class="hidden" id="ghostPaginationFallback">{{pagination}}</div>
        </div>

        <p id="noResults" class="hidden pb-8 text-center text-base font-semibold text-black/60">
            Aucun article ne correspond à votre recherche.
        </p>
    </div>
</section>

<script>
    const searchInput = document.getElementById('searchInput');
    const themeFilter = document.getElementById('themeFilter');
    const noResults = document.getElementById('noResults');
    const grid = document.getElementById('articlesGrid');
    const pagination = document.getElementById('articlesPagination');
    const initialGridHtml = grid?.innerHTML || '';
    const basePath = window.location.pathname.split('/page/')[0].replace(/\/$/, '');

    let allPosts = [];
    let hasLoadedAllPosts = false;

    function escapeHtml(value) {
        return value
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function formatDate(dateString) {
        const date = new Date(dateString);
        const day = String(date.getDate()).padStart(2, '0');
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const year = date.getFullYear();
        return `${day}.${month}.${year}`;
    }

    function createPostCard(post) {
        const safeTitle = escapeHtml(post.title);
        const safeDate = formatDate(post.published_at);
        const safeDateTime = post.published_at.split('T')[0];
        const safeImage = post.feature_image
            ? `<img src="${escapeHtml(post.feature_image)}" alt="${safeTitle}" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />`
            : '<div class="h-full w-full bg-gradient-to-br from-primary to-secondary"></div>';

        const article = document.createElement('article');
        article.className = 'group border-b-2 border-neutral-300 py-6 first:pt-0 last:border-b-0 lg:border-b-0 lg:py-0';
        article.dataset.theme = post.primary_tag?.name || '';

        article.innerHTML = `
            <a href="${escapeHtml(post.url)}" class="block">
                <div class="flex items-start gap-4 lg:block lg:space-y-3">
                    <div class="h-24 w-[8.5rem] shrink-0 overflow-hidden rounded-2xl bg-neutral-300 sm:h-28 sm:w-[9.5rem] lg:h-[11.75rem] lg:w-full lg:rounded-xl">
                        ${safeImage}
                    </div>
                    <div class="min-w-0 flex-1 lg:space-y-2">
                        <h2 class="!font-sans text-[2.25rem] leading-[0.95] font-bold text-fake-black line-clamp-2 lg:text-4xl lg:leading-[1.04]">
                            ${safeTitle}
                        </h2>
                        <div class="mt-3 flex items-center justify-between gap-4 lg:mt-2">
                            <time datetime="${safeDateTime}" class="text-xs font-light text-black/55 sm:text-sm">
                                ${safeDate}
                            </time>
                            <span class="inline-flex shrink-0 items-center rounded-full bg-primary px-4 py-1 text-sm font-bold leading-none text-white sm:px-5 whitespace-nowrap">En savoir plus</span>
                        </div>
                    </div>  
                </div>
            </a>
        `;

        return article;
    }

    function pageUrl(pageNumber) {
        if (pageNumber <= 1) {
            return `${basePath || '/'}/`;
        }
        return `${basePath || ''}/page/${pageNumber}/`;
    }

    function renderPagination() {
        if (!pagination) return;

        const currentPage = Number(pagination.dataset.currentPage || '1');
        const totalPages = Number(pagination.dataset.totalPages || '1');

        if (!Number.isFinite(currentPage) || !Number.isFinite(totalPages) || totalPages <= 1) {
            pagination.innerHTML = '';
            return;
        }

        const nav = document.createElement('nav');
        nav.className = 'flex items-center gap-3 text-sm font-bold text-primary';
        nav.setAttribute('aria-label', 'Pagination des articles');

        const previous = document.createElement('a');
        previous.className = 'inline-flex min-w-28 items-center justify-center rounded-full bg-primary px-4 py-2 text-white transition-opacity hover:opacity-90 disabled:opacity-40';
        previous.textContent = 'Précédent';
        if (currentPage > 1) {
            previous.href = pageUrl(currentPage - 1);
        } else {
            previous.classList.add('pointer-events-none', 'opacity-40');
        }
        nav.appendChild(previous);

        for (let i = 1; i <= totalPages; i += 1) {
            const pageLink = document.createElement('a');
            pageLink.href = pageUrl(i);
            pageLink.className = 'inline-flex size-8 items-center justify-center rounded-full border-2 border-primary text-primary transition-colors hover:bg-primary hover:text-white';
            pageLink.textContent = String(i);

            if (i === currentPage) {
                pageLink.classList.remove('border-2', 'text-primary', 'hover:bg-primary', 'hover:text-white');
                pageLink.classList.add('bg-primary', 'text-white');
                pageLink.setAttribute('aria-current', 'page');
            }

            nav.appendChild(pageLink);
        }

        const next = document.createElement('a');
        next.className = 'inline-flex min-w-28 items-center justify-center rounded-full bg-primary px-4 py-2 text-white transition-opacity hover:opacity-90 disabled:opacity-40';
        next.textContent = 'Suivant';
        if (currentPage < totalPages) {
            next.href = pageUrl(currentPage + 1);
        } else {
            next.classList.add('pointer-events-none', 'opacity-40');
        }
        nav.appendChild(next);

        pagination.innerHTML = '';
        pagination.appendChild(nav);
    }

    async function fetchAllPosts() {
        if (hasLoadedAllPosts) return allPosts;

        try {
            const apiUrl = '{{@site.url}}/ghost/api/content';
            const apiKey = '{{@site.key}}';

            if (!apiKey || apiKey === '') {
                console.error('Cle API Ghost introuvable');
                return [];
            }

            let page = 1;
            const posts = [];

            while (page) {
                const response = await fetch(`${apiUrl}/posts/?key=${apiKey}&limit=100&page=${page}&include=tags`);

                if (!response.ok) {
                    console.error(`API Ghost error: ${response.status}`);
                    break;
                }

                const data = await response.json();
                posts.push(...data.posts);
                page = data.meta?.pagination?.next || null;
            }

            allPosts = posts;
            hasLoadedAllPosts = true;
            return allPosts;
        } catch (error) {
            console.error('Erreur lors du chargement des posts:', error);
            return [];
        }
    }

    function populateThemeFilter(posts) {
        if (!themeFilter) return;

        const previousValue = themeFilter.value;
        
        // Récupère tous les tags uniques de tous les posts (pas seulement primary_tag)
        const allTags = new Set();
        posts.forEach(post => {
            if (post.tags && Array.isArray(post.tags)) {
                post.tags.forEach(tag => {
                    if (tag.name) allTags.add(tag.name);
                });
            }
        });

        const themes = Array.from(allTags).sort((a, b) => a.localeCompare(b, 'fr'));

        themeFilter.innerHTML = '<option value="">Filtres</option>';
        themes.forEach(theme => {
            const option = document.createElement('option');
            option.value = theme.toLowerCase();
            option.textContent = theme;
            themeFilter.appendChild(option);
        });

        if (previousValue && [...themeFilter.options].some(option => option.value === previousValue)) {
            themeFilter.value = previousValue;
        }
    }

    function restoreInitialState() {
        if (grid) grid.innerHTML = initialGridHtml;
        pagination?.classList.remove('hidden');
        noResults?.classList.add('hidden');
    }

    async function applyFilters() {
        const searchTerm = searchInput?.value.trim().toLowerCase() || '';
        const selectedTheme = themeFilter?.value.toLowerCase() || '';

        if (!searchTerm && !selectedTheme) {
            restoreInitialState();
            return;
        }

        try {
            // Assure que les posts sont chargés
            if (!hasLoadedAllPosts) {
                await fetchAllPosts();
            }
            
            const filteredPosts = allPosts.filter(post => {
                // Récupère tous les tags du post
                const postTags = post.tags?.map(tag => tag.name.toLowerCase()) || [];
                
                // Crée un texte avec titre, excerpt et tags pour la recherche
                const searchableText = `${post.title} ${post.excerpt || ''}`.toLowerCase();
                
                // Cherche dans le titre, excerpt et tous les tags
                const matchesSearch = !searchTerm || 
                    searchableText.includes(searchTerm) ||
                    postTags.some(tag => tag.includes(searchTerm));
                
                // Filtre par tag sélectionné
                const matchesTheme = !selectedTheme || 
                    postTags.some(tag => tag === selectedTheme);
                
                return matchesSearch && matchesTheme;
            });

            if (grid) {
                grid.innerHTML = '';
                if (filteredPosts.length > 0) {
                    filteredPosts.forEach(post => grid.appendChild(createPostCard(post)));
                } else {
                    noResults?.classList.remove('hidden');
                }
            }

            pagination?.classList.add('hidden');
            noResults?.classList.toggle('hidden', filteredPosts.length > 0);
        } catch (error) {
            console.error('Erreur lors du filtrage:', error);
            restoreInitialState();
        }
    }

    renderPagination();
    
    // Pré-charge tous les posts et peuple les filtres
    fetchAllPosts().then(posts => {
        populateThemeFilter(posts);
        console.log(`${posts.length} articles chargés pour la recherche`);
    }).catch(error => {
        console.error('Erreur lors du chargement initial:', error);
    });
    
    // Attache les event listeners
    if (searchInput) {
        searchInput.addEventListener('input', applyFilters);
    }
    if (themeFilter) {
        themeFilter.addEventListener('change', applyFilters);
    }
</script>
