{
  "name": "random-theme",
  "description": "Thème personnalisé pour le magazine Random",
  "version": "1.0.0",
  "engines": {
    "ghost": ">=6.0.0"
  },
  "license": "MIT",
  "author": {
    "name": "Random's devs"
  },
  "config": {
    "card_assets": true,
    "posts_per_page": 10,
    "image_sizes": {
      "xxs": {
        "width": 30
      },
      "xs": {
        "width": 100
      },
      "s": {
        "width": 300
      },
      "m": {
        "width": 600
      },
      "l": {
        "width": 1200
      },
      "xl": {
        "width": 2000
      }
    }
  },
  "scripts": {
    "dev": "npx @tailwindcss/cli -i ./assets/css/input.css -o ./assets/css/built.css --watch",
    "build": "npx @tailwindcss/cli -i ./assets/css/input.css -o ./assets/css/built.css --minify"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19"
  }
}
