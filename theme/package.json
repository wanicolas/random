{
	"name": "random-theme",
	"description": "Thème personnalisé pour le magazine Random",
	"version": "1.0.0",
	"engines": {
		"ghost": ">=6.0.0"
	},
	"license": "MIT",
	"author": {
		"name": "Random's devs",
		"email": "devs@random.com"
	},
	"config": {
		"card_assets": true,
		"posts_per_page": 10,
		"image_sizes": {
			"xxs": {
				"width": 30
			},
			"xs": {
				"width": 100
			},
			"s": {
				"width": 300
			},
			"m": {
				"width": 600
			},
			"l": {
				"width": 1200
			},
			"xl": {
				"width": 2000
			}
		}
	},
	"scripts": {
		"dev": "npm run watch:css & npm run watch:js",
		"watch:css": "npx @tailwindcss/cli -i ./assets/css/input.css -o ./assets/built/screen.css --watch",
		"watch:js": "esbuild assets/js/main.js --bundle --platform=browser --format=esm --outfile=assets/built/main.js --sourcemap --watch",
		"build": "npm run build:css && npm run build:js",
		"build:css": "npx @tailwindcss/cli -i ./assets/css/input.css -o ./assets/built/screen.css --minify",
		"build:js": "esbuild assets/js/main.js --bundle --platform=browser --format=esm --outfile=assets/built/main.js --minify",
		"test": "gscan . --verbose",
		"format": "prettier . --write",
		"format:check": "prettier . --check"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.1.18",
		"@tailwindcss/typography": "^0.5.19",
		"gscan": "^5.2.4",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"tailwindcss": "^4.1.18",
		"esbuild": "^0.19.0"
	},
	"dependencies": {
		"lucide": "^0.576.0"
	}
}
