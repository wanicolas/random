{{!< default}}

{{! The tag above means: insert everything in this file
into the {body} tag of the default.hbs template }}

{{! Template pour la page d'accueil (liste des articles) }}

<div class="posts-list space-y-6">
	{{#foreach posts}}
		<article
			class="post-card overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition hover:shadow-md"
		>
			<a href="{{url}}" class="block">
				{{#if feature_image}}
					<div class="post-card-image h-48 overflow-hidden">
						<img
							src="{{feature_image}}"
							alt="{{title}}"
							class="h-full w-full object-cover"
						/>
					</div>
				{{/if}}

				<div class="post-card-content p-6">
					<h2 class="post-card-title mb-3 text-2xl font-bold text-gray-900">
						{{title}}
					</h2>

					<div
						class="post-card-meta mb-3 flex items-center gap-4 text-sm text-gray-500"
					>
						<time datetime="{{date format="YYYY-MM-DD"}}">
							{{date format="DD MMMM YYYY"}}
						</time>
						{{#if primary_author}}
							<span class="post-card-author">par {{primary_author.name}}</span>
						{{/if}}
					</div>

					{{#if excerpt}}
						<p class="post-card-excerpt mb-4 text-gray-600">{{excerpt}}</p>
					{{/if}}

					<span
						class="inline-flex items-center rounded-full bg-[var(--color-primary)] px-6 py-2 text-sm font-semibold text-white transition hover:opacity-90"
					>
						Lire la suite →
					</span>
				</div>
			</a>
		</article>
	{{/foreach}}
</div>

{{! Pagination }}
{{pagination}}