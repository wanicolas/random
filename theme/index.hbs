{{!< default}}

{{! The tag above means: insert everything in this file
into the {body} tag of the default.hbs template }}

{{! Template pour la page d'accueil (liste des articles) }}

  <div class="h-100 bg-gray-200 -mx-6 lg:-mx-20 -mt-6 lg:-mt-20"></div>

  <div class="bg-white rounded-xl -mt-6 -mx-6 lg:-mx-20">
    <div class="p-6">
      <a href="#" id="random-post-btn" class="relative w-fit mx-auto block transition-transform hover:scale-105">
        <img src="./assets/img/accueil.svg" alt="Article aléatoire"  />
        <i data-lucide="mouse-pointer-click" class="size-12.5 stroke-1 text-secondary absolute -right-2 -bottom-4"></i>
      </a>
      
      {{#get "posts" limit="all"}}
      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const postUrls = [
            {{#foreach posts}}
            "{{url}}",
            {{/foreach}}
          ];
          const btn = document.getElementById('random-post-btn');
          if (btn && postUrls.length > 0) {
            btn.addEventListener('click', function(e) {
              e.preventDefault();
              const randomUrl = postUrls[Math.floor(Math.random() * postUrls.length)];
              window.location.href = randomUrl;
            });
          }
        });
      </script>
      {{/get}}
      <div class="my-6 text-center">Accédez directement à un article de façon aléatoire.</div>
      <div class="border-b w-full md:border-b-4 md:border-gray-300 mb-6 lg:mb-12"></div>
    </div>
  
    <div class="flex flex-col justify-center lg:flex-row lg:px-20 lg:gap-40">
      <div class="p-6 max-w-140">
        <h2 class="font-bold text-2xl mb-6 text-center md:text-left uppercase">Découvrez <br> nos derniers articles.</h2>
        <div class="posts-list space-y-6 divide-y">
          {{#foreach posts}}
            <article
              class="post-card pb-6"
            >
              <a href="{{url}}" class="block">
                {{#if feature_image}}
                  <img
                    src="{{feature_image}}"
                    alt="{{title}}"
                    class="post-card-image h-80 rounded-3xl object-cover"
                  />
                {{/if}}
                <div class="post-card-content mt-2">
                  <h2 class="post-card-title mb-1 text-2xl font-bold text-gray-900">
                    {{title}}
                  </h2>
                  {{#if excerpt}}
                    <p class="post-card-excerpt mb-4 text-gray-600">{{excerpt}}</p>
                  {{/if}}
                  <div
                    class="post-card-meta justify-between flex items-center gap-4"
                  >
                    <time datetime="{{date format="YYYY-MM-DD"}}">
                      {{date format="DD MMMM YYYY"}}
                    </time>
                    <span
                      class="rounded-full bg-primary px-6 py-2 text-sm font-semibold text-white transition hover:opacity-90"
                    >
                      En savoir plus
                    </span>
                  </div>
                </div>
              </a>
            </article>
          {{/foreach}}
        </div>

        {{! Pagination }}
        {{pagination}}
      </div>
      
      <div class="lg:order-first lg:w-120 shrink-0 lg:h-180 lg:pb-20 rounded-t-xl lg:rounded-xl -mb-6 bg-gray-200 p-6 flex flex-col justify-between h-120 items-end">
        <button class="w-full rounded-full py-4 px-6 text-2xl uppercase font-bold text-white backdrop-blur-3xl">
          Découvrez notre <br> magazine de poche
        </button>
        <button class="py-1 px-3 rounded-full text-xl uppercase font-bold text-white bg-primary w-fit">S'abonner</button>
      </div>
    </div>
  </div>
  
</div>
