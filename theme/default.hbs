<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    
    {{!-- Styles CSS --}}
    <link rel="stylesheet" href="{{asset "css/style.css"}}">
    
    {{!-- Ghost injecte automatiquement les meta tags, scripts, etc. --}}
    {{ghost_head}}
</head>
<body class="{{body_class}}">
    
    <header class="site-header">
        <div class="container">
            <h1 class="site-title">
                <a href="{{@site.url}}">{{@site.title}}</a>
            </h1>
            <p class="site-description">{{@site.description}}</p>
            
            <nav class="site-nav">
                {{navigation}}
            </nav>
        </div>
    </header>

    <main class="site-main">
        <div class="container">
            {{!-- Tout le contenu de la page sera injecté ici --}}
            {{{body}}}
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <p>&copy; {{date format="YYYY"}} {{@site.title}} - Tous droits réservés</p>
        </div>
    </footer>

    {{!-- Scripts JS --}}
    <script src="{{asset "js/main.js"}}"></script>
    
    {{!-- Ghost injecte les scripts nécessaires --}}
    {{ghost_foot}}
</body>
</html>
