{{!< default}}

{{! Page Actualités avec grille d'articles }}

<div class="min-h-screen pb-24">
    {{! Header avec titre centre et ligne decorative }}
    <header class="px-4 sm:px-6 lg:px-8 pt-8 pb-6">
        <div class="flex flex-col items-center text-center mb-8">
            <h1 class="text-4xl sm:text-5xl font-bold text-[var(--color-primary)]">Actualites</h1>
            <div class="w-52 h-1 bg-[var(--color-primary)] mt-4 rounded-full"></div>
        </div>

        {{! Barre de recherche et filtres a droite }}
        <div class="flex flex-col md:flex-row items-stretch md:items-center gap-3 md:gap-4 max-w-5xl mx-auto">
            <div class="relative flex-1">
                <input
                    type="search"
                    placeholder="Rechercher par titre ou theme..."
                    class="w-full px-4 py-3 pr-12 rounded-full border-2 border-[var(--color-primary)]/40 focus:border-[var(--color-primary)] focus:outline-none text-gray-700 placeholder-gray-400 bg-white"
                    id="searchInput"
                />
                <i data-lucide="search" class="absolute right-4 top-1/2 -translate-y-1/2 size-5 text-[var(--color-primary)]/70"></i>
            </div>

            <div class="md:ml-auto flex items-center gap-2">
                <i data-lucide="filter" class="size-5 text-[var(--color-primary)]"></i>
                <select
                    id="themeFilter"
                    class="min-w-44 px-4 py-3 rounded-full border-2 border-[var(--color-primary)]/40 bg-white text-gray-700 font-semibold focus:border-[var(--color-primary)] focus:outline-none"
                >
                    <option value="">Tous les themes</option>
                </select>
            </div>
        </div>
    </header>

    {{! Grille d'articles }}
    <div class="px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12" id="articlesGrid">
            {{#foreach posts}}
            <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1" data-theme="{{#if primary_tag}}{{primary_tag.name}}{{/if}}">
                <a href="{{url}}" class="block">
                    {{! Image de l'article }}
                    {{#if feature_image}}
                    <div class="relative h-48 sm:h-56 overflow-hidden bg-gray-100">
                        <img
                            src="{{feature_image}}"
                            alt="{{title}}"
                            class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
                    </div>
                    {{else}}
                    <div class="h-48 sm:h-56 bg-gradient-to-br from-[var(--color-primary)]/20 to-[var(--color-secondary)]/20"></div>
                    {{/if}}

                    {{! Contenu de la carte }}
                    <div class="p-5 sm:p-6">
                        {{! Tags (si disponibles) }}
                        {{#if primary_tag}}
                        <span class="article-theme inline-block bg-[var(--color-primary)]/10 text-[var(--color-primary)] text-xs font-bold px-3 py-1 rounded-full mb-3">
                            {{primary_tag.name}}
                        </span>
                        {{/if}}

                        {{! Titre }}
                        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-3 line-clamp-2 hover:text-[var(--color-primary)] transition-colors">
                            {{title}}
                        </h2>

                        {{! Excerpt }}
                        {{#if excerpt}}
                        <p class="text-gray-600 mb-4 line-clamp-2 text-sm sm:text-base">
                            {{excerpt}}
                        </p>
                        {{/if}}

                        {{! Footer avec date et bouton }}
                        <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                            <time
                                datetime="{{date format='YYYY-MM-DD'}}"
                                class="text-sm text-gray-500 flex items-center gap-2"
                            >
                                <i data-lucide="calendar" class="size-4"></i>
                                {{date format="DD MMM YYYY"}}
                            </time>

                            <span class="inline-flex items-center gap-2 bg-[var(--color-primary)] text-white text-sm font-semibold px-5 py-2 rounded-full hover:opacity-90 transition-opacity">
                                En savoir plus
                                <i data-lucide="arrow-right" class="size-4"></i>
                            </span>
                        </div>
                    </div>
                </a>
            </article>
            {{/foreach}}
        </div>

        {{! Pagination }}
        <div class="flex justify-center pb-8" id="articlesPagination">
            {{pagination}}
        </div>

        <p id="noResults" class="hidden text-center text-gray-500 font-semibold pb-8">
            Aucun article ne correspond a votre recherche.
        </p>
    </div>
</div>

<script>
    const searchInput = document.getElementById('searchInput');
    const themeFilter = document.getElementById('themeFilter');
    const noResults = document.getElementById('noResults');
    const grid = document.getElementById('articlesGrid');
    const pagination = document.getElementById('articlesPagination');
    const initialGridHtml = grid?.innerHTML || '';

    let allPosts = [];
    let hasLoadedAllPosts = false;

    function escapeHtml(value = '') {
        return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function formatDate(value) {
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) {
            return '';
        }

        return new Intl.DateTimeFormat('fr-FR', {
            day: '2-digit',
            month: 'short',
            year: 'numeric',
        }).format(date);
    }

    function renderPostCard(post) {
        const title = escapeHtml(post.title || 'Sans titre');
        const excerpt = escapeHtml(post.excerpt || '');
        const url = escapeHtml(post.url || '#');
        const featureImage = post.feature_image;
        const primaryTag = post.primary_tag?.name || '';
        const primaryTagHtml = primaryTag
            ? `<span class="article-theme inline-block bg-[var(--color-primary)]/10 text-[var(--color-primary)] text-xs font-bold px-3 py-1 rounded-full mb-3">${escapeHtml(primaryTag)}</span>`
            : '';
        const dateIso = escapeHtml((post.published_at || '').slice(0, 10));
        const dateLabel = escapeHtml(formatDate(post.published_at));

        const imageHtml = featureImage
            ? `
                <div class="relative h-48 sm:h-56 overflow-hidden bg-gray-100">
                    <img src="${escapeHtml(featureImage)}" alt="${title}" class="w-full h-full object-cover transition-transform duration-300 hover:scale-105" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
                </div>
            `
            : '<div class="h-48 sm:h-56 bg-gradient-to-br from-[var(--color-primary)]/20 to-[var(--color-secondary)]/20"></div>';

        const excerptHtml = excerpt
            ? `<p class="text-gray-600 mb-4 line-clamp-2 text-sm sm:text-base">${excerpt}</p>`
            : '';

        return `
            <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1" data-theme="${escapeHtml(primaryTag)}">
                <a href="${url}" class="block">
                    ${imageHtml}
                    <div class="p-5 sm:p-6">
                        ${primaryTagHtml}
                        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-3 line-clamp-2 hover:text-[var(--color-primary)] transition-colors">${title}</h2>
                        ${excerptHtml}
                        <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                            <time datetime="${dateIso}" class="text-sm text-gray-500">${dateLabel}</time>
                            <span class="inline-flex items-center gap-2 bg-[var(--color-primary)] text-white text-sm font-semibold px-5 py-2 rounded-full hover:opacity-90 transition-opacity">En savoir plus</span>
                        </div>
                    </div>
                </a>
            </article>
        `;
    }

    async function fetchAllPosts() {
        if (hasLoadedAllPosts) {
            return allPosts;
        }

        const ghostScript = document.querySelector('script[data-api][data-key]');
        const apiUrl = ghostScript?.dataset.api;
        const apiKey = ghostScript?.dataset.key;

        if (!apiUrl || !apiKey) {
            return [];
        }

        let page = 1;
        const posts = [];

        while (page) {
            const endpoint = `${apiUrl}posts/?key=${apiKey}&limit=100&page=${page}&include=tags,authors`;
            const response = await fetch(endpoint);

            if (!response.ok) {
                throw new Error(`Ghost API error: ${response.status}`);
            }

            const data = await response.json();
            posts.push(...(data.posts || []));
            page = data.meta?.pagination?.next || null;
        }

        allPosts = posts;
        hasLoadedAllPosts = true;
        return allPosts;
    }

    function refreshThemeOptions(posts) {
        if (!themeFilter) {
            return;
        }

        themeFilter.innerHTML = '<option value="">Tous les themes</option>';

        const themes = [...new Set(
            posts
                .map(post => (post.primary_tag?.name || '').trim())
                .filter(Boolean)
        )].sort((a, b) => a.localeCompare(b, 'fr'));

        themes.forEach(theme => {
            const option = document.createElement('option');
            option.value = theme.toLowerCase();
            option.textContent = theme;
            themeFilter.appendChild(option);
        });
    }

    function restoreInitialState() {
        if (grid) {
            grid.innerHTML = initialGridHtml;
        }

        if (pagination) {
            pagination.classList.remove('hidden');
        }

        if (noResults) {
            noResults.classList.add('hidden');
        }
    }

    async function applyFilters() {
        const searchTerm = (searchInput?.value || '').trim().toLowerCase();
        const selectedTheme = (themeFilter?.value || '').trim().toLowerCase();
        const hasActiveFilters = Boolean(searchTerm || selectedTheme);

        if (!hasActiveFilters) {
            restoreInitialState();
            return;
        }

        try {
            const posts = await fetchAllPosts();
            refreshThemeOptions(posts);

            const filteredPosts = posts.filter(post => {
                const title = (post.title || '').toLowerCase();
                const theme = (post.primary_tag?.name || '').toLowerCase();
                const matchesSearch = !searchTerm || title.includes(searchTerm) || theme.includes(searchTerm);
                const matchesTheme = !selectedTheme || theme === selectedTheme;
                return matchesSearch && matchesTheme;
            });

            if (grid) {
                grid.innerHTML = filteredPosts.map(renderPostCard).join('');
            }

            if (pagination) {
                pagination.classList.add('hidden');
            }

            if (noResults) {
                noResults.classList.toggle('hidden', filteredPosts.length > 0);
            }
        } catch (error) {
            console.error('Erreur de recherche Ghost:', error);
            restoreInitialState();
        }
    }

    // Charge les themes globaux au demarrage pour un filtre coherent meme avec pagination.
    fetchAllPosts().then(refreshThemeOptions).catch(() => {});
    searchInput?.addEventListener('input', applyFilters);
    themeFilter?.addEventListener('change', applyFilters);
</script>
